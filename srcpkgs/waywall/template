configure_args="--prefix=/usr"

do_configure() {
	# Use Meson if the project uses Meson
	meson setup build . "${configure_args[@]}"
}

do_build() {
	ninja -C build
}

do_install() {
	DESTDIR="$PKGDESTDIR" make install
}
