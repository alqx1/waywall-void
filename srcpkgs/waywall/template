revision=1
build_style=gnu-makefile
hostmakedepends="pkg-config meson"
makedepends="wayland-protocols wayland-devel LuaJIT-devel libspng-devel libxkbcommon-devel libfreeglut-devel zlib-devel xorg-server-xwayland"
